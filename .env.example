# Creden credentials — required only if you want directors/share/signers data.
# `creden_lookup` works without these (financials + profile are public),
# but the auth-gated fields will be null with directors_status explaining why.
CREDEN_EMAIL=your-email@example.com
CREDEN_PASSWORD=your-password

# Optional: base URL override
# CREDEN_BASE_URL=https://data.creden.co

# Optional: rate-limit delay between API calls (seconds)
# CREDEN_REQUEST_DELAY=1.5

# Optional: default language (th | en)
# CREDEN_DEFAULT_LANG=th

# Optional: cookie persistence file (relative or absolute)
# CREDEN_SESSION_FILE=.creden_session.json
